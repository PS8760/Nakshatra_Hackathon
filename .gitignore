# Dependencies
frontend/node_modules/
backend/venv/
"cogniscan-ai copy/frontend/node_modules/"
"cogniscan-ai copy/backend/__pycache__/"

# Build outputs
frontend/.next/
frontend/out/

# Environment files (keep examples, ignore actuals)
frontend/.env.local
backend/.env
"cogniscan-ai copy/frontend/.env.local"
"cogniscan-ai copy/backend/.env"

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Database
*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
